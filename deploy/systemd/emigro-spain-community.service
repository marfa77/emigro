[Unit]
Description=Emigro Spain satellite — daily parser, ingest, Gemini draft, spotlight
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
WorkingDirectory=/opt/emigro
ExecStart=/bin/bash /opt/emigro/parser/run_scheduled_spain.sh
User=www-data
EnvironmentFile=-/opt/emigro/parser/.env
EnvironmentFile=-/opt/emigro/.env
StandardOutput=append:/opt/emigro/parser/logs/scheduled-spain.log
StandardError=append:/opt/emigro/parser/logs/scheduled-spain.log

[Install]
WantedBy=multi-user.target
