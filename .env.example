# Supabase — https://supabase.com/dashboard/project/wcwadwcjqutdxwbrkyai
NEXT_PUBLIC_SUPABASE_URL=https://wcwadwcjqutdxwbrkyai.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Google Analytics 4 — measurement ID (defaults to G-9PYSNNXYLY if unset)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-9PYSNNXYLY

# Server-side canonical origin for SEO pings (used when NEXT_PUBLIC_SITE_URL is localhost)
# EMIGRO_PUBLIC_SITE_URL=https://www.emigro.online

# Weekly news digest (Gemini via Google AI Studio)
GOOGLE_API_KEY=
EMIGRO_NEWS_MODEL=gemini-2.5-pro
EMIGRO_NEWS_FAST_MODEL=gemini-2.5-flash
EMIGRO_NEWS_SELECTED_COUNT=5
EMIGRO_NEWS_ORCHESTRATOR_MODEL=gemini-2.5-pro

# Telegram bots (three roles — use separate tokens when possible)
#
# EMIGRO_CHAT_BOT_TOKEN — @emigro_chat_bot (wizard ?start= deep links, admin /stats webhook)
# EMIGRO_BOT_TOKEN — optional alias for EMIGRO_CHAT_BOT_TOKEN (legacy name)
# EMIGRO_NEWS_BOT_TOKEN — publishes weekly digests to @Emigro_news (server-side Bot API)
# TELEGRAM_BOT_TOKEN — legacy fallback if EMIGRO_NEWS_BOT_TOKEN unset (news channel only)
# TELEGRAM_ADMIN_CHAT_ID — numeric chat/user ids for /stats (comma-separated; private chat = same id)
# TELEGRAM_PRIVATE_CHAT_ID — fallback for admin chat id + owner DMs via news bot
# FACTCHECK_NOTIFY_TELEGRAM_CHAT_ID — private DM for volatile guide fact-check alerts (falls back to TELEGRAM_PRIVATE_CHAT_ID)
# TELEGRAM_WEBHOOK_SECRET — optional secret for POST /api/telegram/webhook (X-Telegram-Bot-Api-Secret-Token)
# EMIGRO_NEWS_TELEGRAM_CHANNEL — channel handle for digest publishing
# After deploy: npx tsx scripts/set-telegram-webhook.ts
EMIGRO_BOT_TOKEN=
EMIGRO_NEWS_BOT_TOKEN=
TELEGRAM_BOT_TOKEN=
EMIGRO_CHAT_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=
TELEGRAM_PRIVATE_CHAT_ID=
FACTCHECK_NOTIFY_TELEGRAM_CHAT_ID=
TELEGRAM_WEBHOOK_SECRET=
EMIGRO_NEWS_TELEGRAM_CHANNEL=@Emigro_news

# Discussion group @emigro_chat — linked to @Emigro_news channel (NOT a standalone joinable group).
# Public site CTAs use the channel URL; users access chat via post comments.
# NEXT_PUBLIC_RELOCATOR_CHAT_URL=https://t.me/emigro_chat
# Wizard ?start= deep links only — never use as discussion group URL
# EMIGRO_CHAT_BOT_PUBLIC_URL=https://t.me/emigro_chat_bot
# NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=emigro_chat_bot

# Ops API — add countries / digest without deploy
EMIGRO_ADMIN_SECRET=

# Portugal satellite parser → POST /api/v1/ingest/community-signals (parser/.env COMMUNITY_INGEST_API_KEY)
COMMUNITY_INGEST_API_KEY=

# Site analytics (/admin/stats) — IANA timezone for «сегодня» boundaries (Barakhlo pattern)
EMIGRO_ANALYTICS_TIMEZONE=Europe/Lisbon

# Daily subscriber counts → owner Telegram DM (Vercel cron /api/cron/social-subscribers, 07:00 UTC)
# Telegram is on by default; other platforms are opt-in or require credentials.
# EMIGRO_SOCIAL_STATS_ENABLED=0
# EMIGRO_SOCIAL_STATS_TELEGRAM=0
# EMIGRO_SOCIAL_STATS_THREADS=1          # HTML scrape; off by default (often HTTP 429)
# EMIGRO_SOCIAL_STATS_YOUTUBE=1          # off by default; needs YOUTUBE_API_KEY or EMIGRO_YOUTUBE_* OAuth
# EMIGRO_SOCIAL_STATS_FACEBOOK=0         # force off even with token
# YOUTUBE_API_KEY=                       # or EMIGRO_YOUTUBE_* OAuth for YouTube counts
# FACEBOOK_ACCESS_TOKEN=                 # Graph API; token must see the group
# FACEBOOK_GRAPH_VERSION=v21.0

# Prep2Go news SOURCE: CIPLE A2 Supabase `news_digests` (zvydotrkmfzmamvyrfhv — not Emigro project).
# Emigro `emigro_news_digests` is write-only (translated RU output). RSS fallback if unset/unreachable.
# PREP2GO_SUPABASE_URL=https://zvydotrkmfzmamvyrfhv.supabase.co
# PREP2GO_SUPABASE_ANON_KEY=
# PREP2GO_SUPABASE_SERVICE_ROLE_KEY=

# Vercel cron (Authorization: Bearer <secret> sent automatically by Vercel):
#   GET /api/cron/social-subscribers — daily 07:00 UTC
# Prep2Go news + Portugal community: VPS systemd — see docs/PREP2GO_CRON.md, docs/PORTUGAL_CRON.md
CRON_SECRET=
# Max editorial notes per portugal-community cron run (default 1 — quality over volume)
# PORTUGAL_CRON_MAX_NOTES=1
# Canonical satellite URLs: portugal.emigro.online in production (DNS live).
# Opt out locally or on preview: PORTUGAL_SATELLITE_USE_SUBDOMAIN=false
# PORTUGAL_SATELLITE_USE_SUBDOMAIN=true

# Optional Twitter/X card attribution (e.g. @Emigro_news)
# NEXT_PUBLIC_TWITTER_SITE=
# NEXT_PUBLIC_TWITTER_CREATOR=

# Google Search Console — HTML meta tag content (Вебмастер → Подтверждение → HTML-тег)
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Ping Google sitemap on news publish and `npm run seo:indexnow` (recommended with GSC)
PING_GOOGLE_SITEMAP=1

# Yandex Metrika — numeric counter ID (metrika.yandex.ru → Настройки → код счётчика)
# Enables PF signals + Webmaster «Обход по счётчикам» after linking in Вебмастер.
NEXT_PUBLIC_YANDEX_METRIKA_ID=110252231

# Yandex Webmaster — meta verification (Яндекс.Вебмастер → Настройки → Подтверждение прав)
NEXT_PUBLIC_YANDEX_VERIFICATION=

# Yandex/Bing IndexNow — key file must exist at /{key}.txt in public/
# Primary endpoint: https://yandex.com/indexnow
INDEXNOW_KEY=a13fb4b7cacc4dee87f25aa0b471157a

# YouTube Shorts (@Emigro_news) — evergreen tips, VPS daily (see docs/YOUTUBE_SHORTS_CRON.md)
# OPENAI_API_KEY=sk-...
# GOOGLE_API_KEY=...
# EMIGRO_YOUTUBE_SHORTS_ENABLED=1
# EMIGRO_YOUTUBE_SHORTS_BUCKET=gs://prep2go/prep2go-podcast
# EMIGRO_YOUTUBE_SHORTS_GCS_PREFIX=emigro-shorts
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# GOOGLE_APPLICATION_CREDENTIALS=/opt/emigro/data/gcs-upload-key.json

# YouTube auto-upload (@Emigro_news) — OAuth refresh token (see npm run youtube:oauth-setup)
# EMIGRO_YOUTUBE_CLIENT_ID=...
# EMIGRO_YOUTUBE_CLIENT_SECRET=...
# EMIGRO_YOUTUBE_REFRESH_TOKEN=...
# EMIGRO_YOUTUBE_UPLOAD_ENABLED=1
# EMIGRO_YOUTUBE_UPLOAD_PRIVACY=public
# EMIGRO_YOUTUBE_PLAYLIST_ID=PLxxxx   # optional; else matched by playlist title from metadata

# Dynamic video: B-roll (Pexels) + Ken Burns + kinetic captions + SFX (default on)
# PEXELS_API_KEY=...                  # free at pexels.com/api — without key uses animated gradient fallback
# EMIGRO_YOUTUBE_SHORTS_DYNAMIC=0     # legacy static SVG slides

# Background music under voiceover (~−20 dB). Drop MP3s into data/bgm/
# EMIGRO_BGM_ENABLED=1
# EMIGRO_BGM_VOLUME=0.1
# EMIGRO_BGM_DIR=data/bgm
