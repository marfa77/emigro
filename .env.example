# Supabase — https://supabase.com/dashboard/project/wcwadwcjqutdxwbrkyai
NEXT_PUBLIC_SUPABASE_URL=https://wcwadwcjqutdxwbrkyai.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Weekly news digest (Gemini via Google AI Studio)
GOOGLE_API_KEY=
EMIGRO_NEWS_MODEL=gemini-2.5-pro
EMIGRO_NEWS_FAST_MODEL=gemini-2.5-flash
EMIGRO_NEWS_SELECTED_COUNT=5
EMIGRO_NEWS_ORCHESTRATOR_MODEL=gemini-2.5-pro

# Telegram — @Emigro_news (Threads copy-paste format)
# TELEGRAM_PRIVATE_CHAT_ID — ваш chat id (лиды + Threads copy в личку)
# EMIGRO_NEWS_BOT_TOKEN — бот: канал @Emigro_news (Threads copy-paste) + DM
# TELEGRAM_BOT_TOKEN — запасной бот, если CIPLE не настроен
TELEGRAM_BOT_TOKEN=
EMIGRO_NEWS_BOT_TOKEN=
TELEGRAM_PRIVATE_CHAT_ID=
EMIGRO_NEWS_TELEGRAM_CHANNEL=@Emigro_news

# Ops API — add countries / digest without deploy
EMIGRO_ADMIN_SECRET=

# Vercel cron: GET /api/cron/weekly-news (Vercel sends Authorization: Bearer <secret> automatically)
CRON_SECRET=

# Google Search Console — optional (secondary audience)
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Yandex Webmaster — meta verification (Яндекс.Вебмастер → Настройки → Подтверждение прав)
# NEXT_PUBLIC_YANDEX_VERIFICATION=

# Yandex/Bing IndexNow — key file must exist at /{key}.txt in public/
# Primary endpoint: https://yandex.com/indexnow
INDEXNOW_KEY=a13fb4b7cacc4dee87f25aa0b471157a

# Optional Google sitemap ping after news publish (off by default; audience is Yandex)
# PING_GOOGLE_SITEMAP=1
