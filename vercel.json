{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "crons": [
    {
      "path": "/api/cron/social-subscribers",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/portugal-note-images",
      "schedule": "30 7 * * *"
    },
    {
      "path": "/api/cron/spain-note-images",
      "schedule": "45 7 * * *"
    }
  ],
  "env": {
    "PORTUGAL_SATELLITE_USE_SUBDOMAIN": "true",
    "SPAIN_SATELLITE_USE_SUBDOMAIN": "true"
  }
}
