# Portugal community signals — Telethon parser (Barakhlo pattern)
# First auth: cd parser && python main.py --auth

TG_API_ID=
TG_API_HASH=
SESSION_FILE=tg.session
# VPS / CI: string session instead of file (required on server)
# TG_SESSION_STRING=

# HTTP ingest (optional — VPS daily uses direct Supabase via npm run portugal:daily)
EMIGRO_API_URL=https://www.emigro.online
COMMUNITY_INGEST_API_KEY=

# Incremental cron: recent messages only
PARSER_INCREMENTAL_LIMIT=40
PARSER_MAX_AGE_HOURS=24
PARSER_BOOTSTRAP_LIMIT=100
# Month backfill (--since-days 30)
PARSER_SINCE_DAYS_LIMIT=400
